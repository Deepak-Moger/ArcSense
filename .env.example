# Copy this file to .env.local and add your own keys.
# Never commit .env.local or real secrets.

# Select provider explicitly (optional): anthropic | groq | gemini
AI_PROVIDER=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Groq (OpenAI-compatible endpoint)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: Go backend integration for live scraped feeds
GO_BACKEND_URL=http://localhost:8080
GO_BACKEND_PORT=8080
